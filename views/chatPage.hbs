{{! views/chatPage.hbs }}
<!DOCTYPE html>
<html lang="en">
<head>
    {{> header title=pageTitle}}
</head>
<body>
    {{> navbar_main}}

    <div class="chat-page-wrapper">
        <div class="chat-container">
            <div class="chat-header">
                <div class="container d-flex align-items-center">
                    <a href="javascript:history.back()" class="chat-back-btn me-3" title="Kembali">
                        <i class="bi bi-arrow-left"></i>
                    </a>
                    {{#if receiver.profile_image_url}}
                        <img src="{{receiver.profile_image_url}}" alt="{{receiver.name}}" class="chat-avatar me-2" onerror="this.onerror=null;this.src='https://ui-avatars.com/api/?name={{receiver.name}}&background=random';">
                    {{else}}
                        <img src="https://ui-avatars.com/api/?name={{receiver.name}}&background=random" alt="{{receiver.name}}" class="chat-avatar me-2">
                    {{/if}}
                    <div class="flex-grow-1">
                        <h5 class="chat-receiver-name mb-0">{{receiver.name}}</h5>
                        <small class="chat-status"><i class="bi bi-circle-fill"></i> Online</small>
                    </div>
                </div>
            </div>

            <div class="chat-messages-area" id="chatPageMessagesArea">
                <p class="chat-system-message" id="chatLoadingText">Memuat percakapan...</p>
            </div>

            <div class="chat-footer">
                <div class="container">
                    <form id="chatPageSendMessageForm" class="chat-input-wrapper">
                        <input type="text" class="chat-input" id="chatPageMessageInput" placeholder="Ketik pesan..." autocomplete="off" required>
                        <input type="hidden" id="chatPageCurrentRoomId">
                        <input type="hidden" id="chatPageCurrentReceiverId" value="{{receiver.id}}">
                        <button type="submit" class="chat-send-btn" title="Kirim">
                            <i class="bi bi-send-fill"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    {{> footer_main}}

    <script>
        // socket.io sudah di-inisialisasi di /script.js sebagai global `socket`
        (function() {
            const loggedInUserIdChat = {{#if user}}{{user.id}}{{else}}null{{/if}};
            const receiverIdChat = parseInt('{{receiver.id}}');
            const receiverNameChat = '{{receiver.name}}';

            console.log('[Chat] Init. loggedInUserId=' + loggedInUserIdChat + ' receiverId=' + receiverIdChat);

            document.addEventListener('DOMContentLoaded', function() {
                if (typeof socket === 'undefined') {
                    console.error('[Chat] Socket global not found');
                    const chatArea = document.getElementById('chatPageMessagesArea');
                    if (chatArea) chatArea.innerHTML = '<p class="chat-system-message text-danger">Fitur chat tidak tersedia saat ini.</p>';
                    return;
                }

            const messagesArea = document.getElementById('chatPageMessagesArea');
            const loadingText = document.getElementById('chatLoadingText');
            const messageForm = document.getElementById('chatPageSendMessageForm');
            const messageInput = document.getElementById('chatPageMessageInput');
            const roomIdInput = document.getElementById('chatPageCurrentRoomId');

            function setStatus(text, isError) {
                if (!loadingText) return;
                loadingText.textContent = text;
                loadingText.style.color = isError ? '#dc3545' : '';
            }

            // Timeout fallback: jika 8 detik tidak ada response, tampilkan error
            setTimeout(() => {
                if (loadingText && loadingText.textContent === 'Memuat percakapan...') {
                    setStatus('Koneksi lambat. Coba refresh halaman.', true);
                }
            }, 8000);

            // Socket global sudah diinisialisasi oleh /script.js
            // Jika sudah connected, langsung emit. Jika belum, tunggu event connect.
            function startChatSession() {
                if (loggedInUserIdChat && !isNaN(receiverIdChat) && loggedInUserIdChat !== receiverIdChat) {
                    console.log('[Chat] Emitting initiateChat for sellerId=' + receiverIdChat);
                    socket.emit('initiateChat', { sellerId: receiverIdChat });
                } else if (loggedInUserIdChat === receiverIdChat) {
                    if(messagesArea) messagesArea.innerHTML = '<p class="chat-system-message">Anda tidak bisa chat dengan diri sendiri.</p>';
                } else if (!loggedInUserIdChat) {
                    if(messagesArea) messagesArea.innerHTML = '<p class="chat-system-message">Silakan <a href="/login">login</a> untuk memulai chat.</p>';
                } else {
                    setStatus('Tidak dapat memulai chat: ID tidak valid.', true);
                }
            }
            if (socket.connected) {
                console.log('[Chat] Socket already connected:', socket.id);
                startChatSession();
            } else {
                socket.once('connect', () => {
                    console.log('[Chat] Socket connected:', socket.id);
                    startChatSession();
                });
            }

            socket.on('disconnect', () => {
                console.log('[Chat] Socket disconnected');
                setStatus('Koneksi terputus. Menyambungkan ulang...', true);
            });

            socket.on('connect_error', (err) => {
                console.error('[Chat] Connection error:', err.message);
                setStatus('Gagal menyambung ke server chat. Coba refresh halaman.', true);
            });

            if (messageForm) {
                messageForm.addEventListener('submit', function(event) {
                    event.preventDefault();
                    const text = messageInput.value.trim();
                    const currentRoomId = roomIdInput.value;

                    if (text && currentRoomId && loggedInUserIdChat && !isNaN(receiverIdChat)) {
                        socket.emit('sendMessage', {
                            roomId: currentRoomId,
                            receiverId: receiverIdChat,
                            text: text
                        });
                        appendChatMessage({
                            senderId: loggedInUserIdChat,
                            messageText: text,
                            sentAt: new Date().toISOString(),
                            isOptimistic: true
                        });
                        scrollToBottomChatPage();
                        messageInput.value = '';
                    } else {
                        console.warn('[Chat] Cannot send. text=' + !!text + ' roomId=' + currentRoomId);
                    }
                });
            }

            socket.on('chatSessionStarted', (data) => {
                console.log('[Chat] chatSessionStarted:', data);
                if (messagesArea) messagesArea.innerHTML = '';
                if (roomIdInput) roomIdInput.value = data.roomId;

                if (data.messages && data.messages.length > 0) {
                    data.messages.forEach(msg => appendChatMessage(msg));
                } else {
                    appendChatMessage({ systemMessage: "Belum ada pesan. Mulai percakapan!" });
                }
                scrollToBottomChatPage();
            });

            socket.on('newMessage', (message) => {
                console.log('[Chat] newMessage:', message);
                const currentRoomId = roomIdInput ? roomIdInput.value : null;
                if (message.roomId === currentRoomId) {
                    if (message.senderId !== loggedInUserIdChat) {
                        appendChatMessage(message);
                        scrollToBottomChatPage();
                    } else {
                        const optimisticMsgEl = document.querySelector(`.chat-bubble[data-temp-id="${(message.messageText || message.text).substring(0,15)}-${message.senderId}"]`);
                        if(optimisticMsgEl) {
                            optimisticMsgEl.removeAttribute('data-temp-id');
                            optimisticMsgEl.setAttribute('data-message-id', message.id);
                            optimisticMsgEl.style.opacity = '1';
                            const timeEl = optimisticMsgEl.querySelector('.msg-time');
                            if(timeEl) timeEl.textContent = formatChatPageTimestamp(message.sentAt);
                        } else {
                            if (!document.querySelector(`.chat-bubble[data-message-id="${message.id}"]`)) {
                                appendChatMessage(message);
                                scrollToBottomChatPage();
                            }
                        }
                    }
                }
            });

            socket.on('chatError', (errorData) => {
                console.error('[Chat] chatError:', errorData.message);
                if (messagesArea) {
                    appendChatMessage({ systemMessage: `Error: ${errorData.message}` });
                }
            });

            function appendChatMessage(msg) {
                if (!messagesArea) return;
                const loadingMsg = messagesArea.querySelector('p.chat-system-message');
                if (loadingMsg && !msg.systemMessage) loadingMsg.remove();

                const msgDiv = document.createElement('div');
                msgDiv.classList.add('chat-bubble');

                if (msg.systemMessage) {
                    msgDiv.classList.add('chat-system-message');
                    msgDiv.textContent = msg.systemMessage;
                } else {
                    const isMyMessage = msg.senderId === loggedInUserIdChat;
                    msgDiv.classList.add(isMyMessage ? 'sent' : 'received');

                    if (msg.isOptimistic) {
                        msgDiv.setAttribute('data-temp-id', `${(msg.messageText || msg.text).substring(0,15)}-${msg.senderId}`);
                        msgDiv.style.opacity = '0.7';
                    } else if (msg.id) {
                        msgDiv.setAttribute('data-message-id', msg.id);
                    }

                    const messageContent = escapeHTML(msg.messageText || msg.text);
                    const timeString = formatChatPageTimestamp(msg.sentAt);
                    msgDiv.innerHTML = `<div class="msg-text">${messageContent}</div><div class="msg-time">${timeString}</div>`;
                }
                messagesArea.appendChild(msgDiv);
            }

            function scrollToBottomChatPage() {
                if (messagesArea) messagesArea.scrollTop = messagesArea.scrollHeight;
            }

            function escapeHTML(str) {
                if (typeof str !== 'string') return '';
                return str.replace(/[&<>"']/g, m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[m]);
            }

            function formatChatPageTimestamp(timestamp) {
                if (!timestamp) return new Date().toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
                try { return new Date(timestamp).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }); }
                catch (e) { return ''; }
            }
            }); // end DOMContentLoaded
        })();
    </script>
</body>
</html>
