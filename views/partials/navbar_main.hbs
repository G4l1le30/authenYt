{{! views/partials/navbar_main.hbs }}
<nav class="navbar navbar-expand-lg navbar-light bg-white fixed-top custom-navbar py-1 py-lg-2">
    <div class="container">
        <a class="navbar-brand fw-bold d-flex align-items-center" href="/">
            <img
                src="/img/logo/LOGO FINAL.png"
                alt="company logo"
                class="img-fluid ms-2" {{!-- Dulu ada me-2, mungkin maksudnya me-2 (margin end) atau ms-2 (margin start) --}}
                style="max-height: 40px;"
            />
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDesktop" aria-controls="navbarNavDesktop" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNavDesktop">
            <ul class="navbar-nav mx-auto">
                <li class="nav-item">
                    <a class="nav-link" href="/">Home</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/allProduk">Shop</a>
                </li>
            </ul>
            <div class="d-flex align-items-center navbar-icons">
                <a href="#" class="nav-icon-item me-3" data-bs-toggle="modal" data-bs-target="#searchModal" title="Search"><i class="bi bi-search"></i></a>

                <a href="/dashboard?tab=cart-pane-dash" class="nav-icon-item me-3 position-relative" title="View Cart">
                    <i class="bi bi-cart3"></i>
                    {{#if user.cartItemCount}} {{!-- Asumsi Anda punya user.cartItemCount dari middleware --}}
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="cartItemCountNavbar">
                            {{user.cartItemCount}}
                            <span class="visually-hidden">items in cart</span>
                        </span>
                    {{/if}}
                </a>

                {{#if user}}
                <div class="dropdown" style="position: relative;">
                    <button class="btn btn-link nav-icon-item p-0 border-0 text-dark" type="button" id="customAccountBtn" title="My Account" onclick="toggleCustomDropdown(event)">
                        <i class="bi bi-person-circle fs-4"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm" id="customAccountMenu" style="z-index: 9999; position: absolute; right: 0; min-width: 200px;">
                        <li><h6 class="dropdown-header fs-sm text-muted">Halo, {{user.name}}!</h6></li>
                        <li>
                            <span class="dropdown-item-text">
                                <i class="bi bi-wallet2 me-2 text-success"></i>Saldo:
                                <strong class="text-success">{{{formatRupiah user.balance}}}</strong>
                            </span>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="/dashboard"><i class="bi bi-person-fill me-2"></i>Profil Saya</a></li>
                        <li><a class="dropdown-item" href="/sell"><i class="bi bi-tags-fill me-2"></i>Jual Produk</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="/auth/logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                    </ul>
                </div>
                
                <script>
                    function toggleCustomDropdown(e) {
                        e.preventDefault();
                        e.stopPropagation();
                        var menu = document.getElementById('customAccountMenu');
                        var btn = document.getElementById('customAccountBtn');
                        
                        if (menu.style.display === 'block') {
                            menu.style.display = 'none';
                            btn.classList.remove('show');
                        } else {
                            menu.style.display = 'block';
                            menu.style.opacity = '1';
                            menu.style.visibility = 'visible';
                            btn.classList.add('show');
                        }
                    }

                    // Tutup dropdown saat klik di luar
                    document.addEventListener('click', function(e) {
                        var menu = document.getElementById('customAccountMenu');
                        var btn = document.getElementById('customAccountBtn');
                        if (menu && btn && menu.style.display === 'block') {
                            if (!menu.contains(e.target) && !btn.contains(e.target)) {
                                menu.style.display = 'none';
                                btn.classList.remove('show');
                            }
                        }
                    });
                </script>
                {{else}}
                <a href="/login" class="nav-icon-item" title="Login/Register"><i class="bi bi-person-circle"></i></a>
                {{/if}}
            </div>
        </div>
    </div>
</nav>

{{!-- Modal Search --}}
<div class="modal fade" id="searchModal" tabindex="-1" aria-labelledby="searchModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title w-100 text-center" id="searchModalLabel">Cari Produk</h5>
                <button type="button" class="btn-close position-absolute end-0 me-3" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form action="/allProduk" method="GET" class="d-flex">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text" name="q" class="form-control border-start-0 ps-0" placeholder="Ketik nama baju..." required autofocus>
                        <button class="btn btn-dark" type="submit">Cari</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
